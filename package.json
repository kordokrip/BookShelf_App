{
  "name": "bookshelf-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev --local",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:worker\"",
    "build": "vite build",
    "build:worker": "echo 'Worker is bundled by wrangler deploy — no separate build needed'",
    "preview": "vite preview",
    "predeploy": "npm run docs:coverage-check",
    "deploy": "bash scripts/predeploy-guard.sh && npm run build && wrangler deploy",
    "db:create": "wrangler d1 create bookshelf-db",
    "db:migrate": "wrangler d1 migrations apply bookshelf-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply bookshelf-db --local",
    "db:migrate:status": "wrangler d1 migrations list bookshelf-db --remote",
    "db:studio": "wrangler d1 studio bookshelf-db",
    "type-check": "tsc --noEmit",
    "pwa:ios-startup": "node scripts/generate-ios-startup-images.mjs",
    "pwa:assets": "node scripts/generate-icons.mjs && npm run pwa:ios-startup",
    "docs:coverage-check": "for x in collections discover push share admin useCollections useDiscover useOfflineQueue usePushNotification useViewport 0005_collections 0006_push_subscriptions 0009_indexes_and_session_unique /collections /api/collections /api/discover /api/push /share /api/admin; do rg -n \"$x\" PROJECT_STATUS.md docs/TRACE_MAP.md docs/BookShelf_UI_UX.md >/dev/null && echo \"OK $x\" || { echo \"MISS $x\"; exit 1; }; done",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"worker/**/*.ts\""
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@hono/zod-validator": "^0.7.6",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "@tanstack/react-query": "^5.90.21",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "hono": "^4.12.4",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "react-router": "7.13.0",
    "recharts": "2.15.2",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.3",
    "vite": "6.3.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.10",
    "workbox-window": "^7.4.0",
    "wrangler": "^4.70.0"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
