# ─────────────────────────────────────────────────────────────
# BookShelf — 환경 변수 템플릿
# 이 파일을 .env.local 로 복사 후 실제 값을 입력하세요.
# .env.local 은 절대 Git 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────

# Vite 빌드 환경 (development | production)
VITE_APP_ENV=development

# Worker API 베이스 URL
# 로컬 개발: 빈 문자열 (vite.config.ts 프록시 사용)
# 프로덕션: https://bookshelf-api.<your-subdomain>.workers.dev
VITE_API_BASE_URL=
