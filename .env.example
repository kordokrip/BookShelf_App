# ─────────────────────────────────────────────────────────────
# BookShelf — 환경 변수 템플릿
# 이 파일을 .env.local 로 복사 후 실제 값을 입력하세요.
# .env.local 은 절대 Git 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────

# Vite 빌드 환경 (development | production)
VITE_APP_ENV=development

# Worker API 베이스 URL
# 로컬 개발: 빈 문자열 (vite.config.ts 프록시 사용)
# 프로덕션: https://bookshelf-api.<your-subdomain>.workers.dev
VITE_API_BASE_URL=

# Google OAuth 클라이언트 ID (Google Cloud Console > APIs & Services > Credentials)
# https://console.cloud.google.com/apis/credentials
# ⚠️ 프로덕션 배포 시 GitHub Actions repo secret으로도 동일한 값을 등록해야 합니다
#    (Settings > Secrets and variables > Actions > VITE_GOOGLE_CLIENT_ID)
#    누락 시 배포된 빌드에서 구글 로그인 버튼이 조용히 비활성화됩니다.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
