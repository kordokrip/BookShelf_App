# ─────────────────────────────────────────────────────────────
# BookShelf — 환경 변수 템플릿
# 이 파일을 .env.local 로 복사 후 실제 값을 입력하세요.
# .env.local 은 절대 Git 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────

# Vite 빌드 환경 (development | production)
VITE_APP_ENV=development

# Worker API 베이스 URL
# 로컬 개발: 빈 문자열 (vite.config.ts 프록시 사용)
# 프로덕션: https://bookshelf-api.<your-subdomain>.workers.dev
VITE_API_BASE_URL=

# 카카오 OAuth REST API 키 (카카오 디벨로퍼스 앱 정보 > 앱 키 > REST API 키)
VITE_KAKAO_REST_API_KEY=your-kakao-rest-api-key-here

# 카카오 JavaScript 키 (앱 정보 > 앱 키 > JavaScript 키)
VITE_KAKAO_JS_KEY=your-kakao-js-key-here

# 카카오 OAuth 콜백 URI (Worker URL, 카카오 디벨로퍼스에 등록 필수)
# 로컀 개발 시 카카오 콘솔에 localhost도 포함 등록 후 옵션 설정
VITE_KAKAO_REDIRECT_URI=https://bookshelf-api.kordokrip.workers.dev/api/auth/kakao/callback
